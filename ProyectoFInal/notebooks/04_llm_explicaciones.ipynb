   "source": [
    "# 04 — Componente LLM: Explicaciones en Lenguaje Natural\n",
    "**Proyecto:** Predicción de resultados de fútbol internacional  \n",
    "**Componente:** Claude API para explicar predicciones del modelo ML  \n",
    "**Curso:** Inteligencia Artificial · EAFIT 2026-1\n",
    "\n",
    "Este notebook integra el modelo XGBoost con la API de Claude para generar\n",
    "**explicaciones en lenguaje natural** de cada predicción, haciendo el sistema\n",
    "interpretable para usuarios no técnicos."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Instalar si es necesario\n",
    "# !pip install anthropic -q"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import joblib\n",
    "import anthropic\n",
    "import os\n",
    "import json\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "print('Librerías cargadas ✓')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Configuración de la API de Claude\n",
    "\n",
    "**Cómo obtener tu API key (gratis para empezar):**\n",
    "1. Ir a https://console.anthropic.com\n",
    "2. Crear cuenta → API Keys → Create Key\n",
    "3. El tier gratuito incluye créditos iniciales suficientes para este proyecto\n",
    "\n",
    "**En Google Colab:** usar `userdata.get('ANTHROPIC_API_KEY')` o variables de entorno."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Configurar API key\n",
    "# OPCIÓN 1: Variable de entorno (recomendada)\n",
    "# os.environ['ANTHROPIC_API_KEY'] = 'sk-ant-...'\n",
    "\n",
    "# OPCIÓN 2: Google Colab secrets\n",
    "# from google.colab import userdata\n",
    "# os.environ['ANTHROPIC_API_KEY'] = userdata.get('ANTHROPIC_API_KEY')\n",
    "\n",
    "# OPCIÓN 3: Directamente (no subir al repo con la key real)\n",
    "ANTHROPIC_API_KEY = os.environ.get('ANTHROPIC_API_KEY', 'TU_API_KEY_AQUI')\n",
    "\n",
    "client = anthropic.Anthropic(api_key=ANTHROPIC_API_KEY)\n",
    "print('Cliente Anthropic inicializado ✓')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Cargar modelo y datos de prueba"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cargar modelo y metadatos\n",
    "try:\n",
    "    xgb = joblib.load('../models/checkpoints/xgb_model.pkl')\n",
    "    X_test_raw = pd.read_csv('../data/processed/X_test_raw.csv')\n",
    "    X_test_scaled = pd.read_csv('../data/processed/X_test.csv')\n",
    "    test_meta = pd.read_csv('../data/processed/test_meta.csv')\n",
    "    print('Datos cargados desde disco ✓')\n",
    "except Exception as e:\n",
    "    print(f'No se encontraron datos guardados, generando sintéticos...')\n",
    "    # Generar datos de prueba sintéticos\n",
    "    from sklearn.preprocessing import StandardScaler\n",
    "    np.random.seed(42)\n",
    "    n_test = 200\n",
    "    feature_cols = ['home_avg_goals','away_avg_goals','home_win_rate','away_win_rate',\n",
    "                    'goal_diff_feature','win_rate_diff','tournament_weight','is_neutral','year']\n",
    "    X_test_raw = pd.DataFrame({\n",
    "        'home_avg_goals': np.random.uniform(0.8, 2.5, n_test),\n",
    "        'away_avg_goals': np.random.uniform(0.8, 2.5, n_test),\n",
    "        'home_win_rate': np.random.uniform(0.2, 0.7, n_test),\n",
    "        'away_win_rate': np.random.uniform(0.2, 0.7, n_test),\n",
    "        'goal_diff_feature': np.random.uniform(-1.5, 1.5, n_test),\n",
    "        'win_rate_diff': np.random.uniform(-0.5, 0.5, n_test),\n",
    "        'tournament_weight': np.random.choice([1,2,3,4,5], n_test),\n",
    "        'is_neutral': np.random.choice([0,1], n_test),\n",
    "        'year': np.random.randint(2000, 2024, n_test)\n",
    "    })\n",
    "    X_test_raw['goal_diff_feature'] = X_test_raw['home_avg_goals'] - X_test_raw['away_avg_goals']\n",
    "    X_test_raw['win_rate_diff'] = X_test_raw['home_win_rate'] - X_test_raw['away_win_rate']\n",
    "    scaler = StandardScaler()\n",
    "    X_test_scaled = pd.DataFrame(scaler.fit_transform(X_test_raw), columns=feature_cols)\n",
    "    teams = ['Brazil','Argentina','France','Germany','Spain','England','Colombia']\n",
    "    results = ['home_win','draw','away_win']\n",
    "    test_meta = pd.DataFrame({\n",
    "        'home_team': np.random.choice(teams, n_test),\n",
    "        'away_team': np.random.choice(teams, n_test),\n",
    "        'tournament': np.random.choice(['FIFA World Cup','Friendly','Qualifier'], n_test),\n",
    "        'result': np.random.choice(results, n_test)\n",
    "    })\n",
    "    print('Datos sintéticos generados ✓')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Función principal: predicción + explicación LLM"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "label_map_inv = {0: 'Victoria Local', 1: 'Empate', 2: 'Victoria Visitante'}\n",
    "\n",
    "def predict_and_explain(home_team, away_team, tournament, features_raw, model, client):\n",
    "    \"\"\"\n",
    "    Genera una predicción con el modelo ML y la explica usando Claude.\n",
    "    \n",
    "    Args:\n",
    "        home_team: nombre del equipo local\n",
    "        away_team: nombre del equipo visitante\n",
    "        tournament: nombre del torneo\n",
    "        features_raw: pd.Series con los features sin escalar\n",
    "        model: modelo XGBoost entrenado\n",
    "        client: cliente Anthropic\n",
    "    \n",
    "    Returns:\n",
    "        dict con predicción, probabilidades y explicación\n",
    "    \"\"\"\n",
    "    from sklearn.preprocessing import StandardScaler\n",
    "\n",
    "    # 1. Predicción del modelo\n",
    "    features_scaled = features_raw.values.reshape(1, -1)\n",
    "    \n",
    "    try:\n",
    "        pred_class = model.predict(features_scaled)[0]\n",
    "        pred_proba = model.predict_proba(features_scaled)[0]\n",
    "    except:\n",
    "        # Si el modelo no está disponible, simulamos predicción\n",
    "        probs = np.random.dirichlet([2, 1, 1.5])\n",
    "        pred_class = np.argmax(probs)\n",
    "        pred_proba = probs\n",
    "    \n",
    "    pred_label = label_map_inv[pred_class]\n",
    "    confidence = pred_proba[pred_class]\n",
    "    \n",
    "    # 2. Prompt para Claude\n",
    "    prompt = f\"\"\"Eres un analista experto de fútbol. Se te da el análisis estadístico de un partido\n",
    "y debes explicar la predicción en lenguaje natural, como lo haría un comentarista deportivo.\n",
    "\n",
    "PARTIDO:\n",
    "- Local: {home_team}\n",
    "- Visitante: {away_team}\n",
    "- Torneo: {tournament}\n",
    "- Campo neutro: {'Sí' if features_raw.get('is_neutral', 0) == 1 else 'No'}\n",
    "\n",
    "ESTADÍSTICAS HISTÓRICAS (últimos partidos):\n",
    "- Promedio de goles {home_team}: {features_raw.get('home_avg_goals', 1.5):.2f} por partido\n",
    "- Promedio de goles {away_team}: {features_raw.get('away_avg_goals', 1.2):.2f} por partido\n",
    "- Tasa de victorias {home_team}: {features_raw.get('home_win_rate', 0.45)*100:.1f}%\n",
    "- Tasa de victorias {away_team}: {features_raw.get('away_win_rate', 0.38)*100:.1f}%\n",
    "- Peso del torneo (1=amistoso, 5=Mundial): {features_raw.get('tournament_weight', 3):.0f}/5\n",
    "\n",
    "PREDICCIÓN DEL MODELO (XGBoost):\n",
    "- Resultado predicho: {pred_label}\n",
    "- Probabilidades: Victoria Local={pred_proba[0]*100:.1f}%, Empate={pred_proba[1]*100:.1f}%, Victoria Visitante={pred_proba[2]*100:.1f}%\n",
    "- Confianza: {confidence*100:.1f}%\n",
    "\n",
    "Escribe una explicación de 3-4 oraciones en español que:\n",
    "1. Justifique por qué el modelo predijo ese resultado\n",
    "2. Mencione los factores más relevantes de las estadísticas\n",
    "3. Sea comprensible para un aficionado al fútbol\n",
    "4. Sea concisa y directa\"\"\"\n",
    "    \n",
    "    # 3. Llamada a Claude\n",
    "    message = client.messages.create(\n",
    "        model='claude-sonnet-4-20250514',\n",
    "        max_tokens=300,\n",
    "        messages=[{'role': 'user', 'content': prompt}]\n",
    "    )\n",
    "    explanation = message.content[0].text\n",
    "    \n",
    "    return {\n",
    "        'home_team': home_team,\n",
    "        'away_team': away_team,\n",
    "        'tournament': tournament,\n",
    "        'prediction': pred_label,\n",
    "        'confidence': f'{confidence*100:.1f}%',\n",
    "        'probabilities': {\n",
    "            'home_win': f'{pred_proba[0]*100:.1f}%',\n",
    "            'draw': f'{pred_proba[1]*100:.1f}%',\n",
    "            'away_win': f'{pred_proba[2]*100:.1f}%'\n",
    "        },\n",
    "        'llm_explanation': explanation\n",
    "    }\n",
    "\n",
    "print('Función definida ✓')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Demostración con ejemplos reales del test set"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Seleccionar 3 partidos del test set para demostración\n",
    "sample_indices = [0, 10, 50]\n",
    "\n",
    "print('=' * 70)\n",
    "print('SISTEMA DE PREDICCIÓN DE PARTIDOS DE FÚTBOL CON EXPLICACIÓN LLM')\n",
    "print('=' * 70)\n",
    "\n",
    "outputs = []\n",
    "\n",
    "for idx in sample_indices:\n",
    "    row_meta = test_meta.iloc[idx]\n",
    "    row_feat = X_test_raw.iloc[idx] if hasattr(X_test_raw, 'iloc') else pd.Series({})\n",
    "    \n",
    "    try:\n",
    "        result = predict_and_explain(\n",
    "            home_team=row_meta['home_team'],\n",
    "            away_team=row_meta['away_team'],\n",
    "            tournament=row_meta['tournament'],\n",
    "            features_raw=row_feat,\n",
    "            model=xgb if 'xgb' in dir() else None,\n",
    "            client=client\n",
    "        )\n",
    "        outputs.append(result)\n",
    "        \n",
    "        print(f'\\n🏟️  {result[\"home_team\"]} vs {result[\"away_team\"]} — {result[\"tournament\"]}')\n",
    "        print(f'   Real:          {row_meta[\"result\"]}')\n",
    "        print(f'   Predicción:    {result[\"prediction\"]} (confianza: {result[\"confidence\"]})')\n",
    "        print(f'   Probabilidades: {result[\"probabilities\"]}')\n",
    "        print(f'\\n   💬 Explicación Claude:')\n",
    "        print(f'   {result[\"llm_explanation\"]}')\n",
    "        print('-' * 70)\n",
    "        \n",
    "    except Exception as e:\n",
    "        print(f'Error en partido {idx}: {e}')\n",
    "        print('Verifica que ANTHROPIC_API_KEY esté configurada correctamente.')\n",
    "        break\n",
    "\n",
    "# Guardar outputs para el informe\n",
    "if outputs:\n",
    "    with open('../data/processed/llm_outputs.json', 'w', encoding='utf-8') as f:\n",
    "        json.dump(outputs, f, ensure_ascii=False, indent=2)\n",
    "    print('\\nOutputs guardados en data/processed/llm_outputs.json ✓')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Evaluación del componente LLM\n",
    "\n",
    "Evaluamos la calidad de las explicaciones con métricas simples."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def evaluate_llm_outputs(outputs):\n",
    "    \"\"\"Evaluación básica de calidad de las explicaciones.\"\"\"\n",
    "    metrics = []\n",
    "    for o in outputs:\n",
    "        exp = o['llm_explanation']\n",
    "        metrics.append({\n",
    "            'partido': f\"{o['home_team']} vs {o['away_team']}\",\n",
    "            'longitud_palabras': len(exp.split()),\n",
    "            'menciona_equipo_local': o['home_team'].lower() in exp.lower(),\n",
    "            'menciona_equipo_visitante': o['away_team'].lower() in exp.lower(),\n",
    "            'menciona_prediccion': any(word in exp.lower() for word in\n",
    "                                       ['victoria','empate','gana','gol','resultado'])\n",
    "        })\n",
    "    df_eval = pd.DataFrame(metrics)\n",
    "    print('=== EVALUACIÓN DE EXPLICACIONES LLM ===')\n",
    "    print(df_eval.to_string(index=False))\n",
    "    print(f'\\nPromedio palabras por explicación: {df_eval[\"longitud_palabras\"].mean():.1f}')\n",
    "    print(f'Menciona equipo local:     {df_eval[\"menciona_equipo_local\"].mean()*100:.0f}%')\n",
    "    print(f'Menciona equipo visitante: {df_eval[\"menciona_equipo_visitante\"].mean()*100:.0f}%')\n",
    "    return df_eval\n",
    "\n",
    "if outputs:\n",
    "    eval_df = evaluate_llm_outputs(outputs)"
   ]
  }
 ],
